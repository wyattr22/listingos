generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionPlan {
  FREE
  PRO
  TEAM
}

model User {
  id                         String             @id @default(cuid())
  clerkUserId                String?            @unique
  email                      String             @unique
  name                       String?
  image                      String?
  crmId                      String?
  stripeCustomerId           String?            @unique
  stripeSubscriptionId       String?            @unique
  stripePriceId              String?
  subscriptionPlan           SubscriptionPlan   @default(FREE)
  subscriptionCurrentPeriodEnd DateTime?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  deals                      Deal[]
  analyses                   AnalysisResult[]
  listings                   Listing[]
  apiLogs                    ApiLog[]
  processedWebhookEvents     ProcessedWebhookEvent[]
}

model Deal {
  id              String           @id @default(cuid())
  userId          String
  name            String?
  purchasePrice   Decimal          @db.Decimal(12, 2)
  monthlyRent     Decimal          @db.Decimal(12, 2)
  monthlyExpenses Decimal          @db.Decimal(12, 2)
  downPayment     Decimal          @db.Decimal(12, 2)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisResults AnalysisResult[]
  listings        Listing[]

  @@index([userId, createdAt])
}

model AnalysisResult {
  id               String   @id @default(cuid())
  userId           String
  dealId           String
  mortgageEstimate Decimal  @db.Decimal(12, 2)
  monthlyCashFlow  Decimal  @db.Decimal(12, 2)
  capRate          Decimal  @db.Decimal(6, 2)
  cashOnCashReturn Decimal  @db.Decimal(6, 2)
  riskScore        Decimal  @db.Decimal(5, 2)
  marketScore      Decimal  @db.Decimal(5, 2)
  overallScore     Decimal  @db.Decimal(5, 2)
  roi              Decimal  @db.Decimal(6, 2)
  recommendation   String
  createdAt        DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([dealId, createdAt])
}

model Listing {
  id              String   @id @default(cuid())
  userId          String
  dealId          String?
  sourceInput     Json
  content         String
  meta            Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal            Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([dealId, createdAt])
}

model ProcessedWebhookEvent {
  id          String   @id @default(cuid())
  userId      String?
  provider    String
  eventId     String
  eventType   String
  processedAt DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([processedAt])
}

model RedfinMarketData {
  id               String   @id @default(cuid())
  zipCode          String
  stateCode        String
  periodBegin      DateTime
  medianSalePrice  Float?
  medianListPrice  Float?
  medianPpsf       Float?
  homesSold        Float?
  inventory        Float?
  medianDom        Float?
  avgSaleToList    Float?
  soldAboveList    Float?
  priceDrops       Float?
  metroRegion      String?

  @@unique([zipCode, periodBegin])
  @@index([zipCode, periodBegin(sort: Desc)])
  @@index([stateCode])
}

model ApiLog {
  id         String   @id @default(cuid())
  userId     String?
  endpoint   String
  method     String
  statusCode Int?
  success    Boolean
  message    String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([endpoint, createdAt])
  @@index([userId, createdAt])
}
